## Funcion para r1
f1Summary <- function(data, lev = NULL, model = NULL) {
# Matriz de confusión
cm <- caret::confusionMatrix(data$pred, data$obs, positive = lev[2])
precision <- cm$byClass["Precision"]
recall    <- cm$byClass["Recall"]
f1 <- 2 * (precision * recall) / (precision + recall)
c(F1 = f1)
}
